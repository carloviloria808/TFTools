# Copy to .env and set your own value.
# Password for the frontend admin gate (/admin/login).
VITE_ADMIN_PASSWORD=changeme

# Backend API base URL. Leave unset locally (defaults to http://localhost:5232/api).
# On Vercel, set this to your Render backend, e.g. https://tftools-api.onrender.com/api
# VITE_API_URL=https://your-backend.onrender.com/api
